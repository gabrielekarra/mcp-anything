    {% endif %}
    {% endfor %}
    {% endif %}
    {% endif %}
    ) -> str:
        """{{ tool.description | safe_docstring }}"""
    {% if tool.impl.strategy == "http_call" %}
        # HTTP {{ tool.impl.http_method }} {{ tool.impl.http_path }}
        path_params: dict[str, str] = {}
        query_params: dict[str, str] = {}
        request_body: dict | None = None
        {% for param in tool.parameters %}
        {% if tool.impl.arg_mapping.get(param.name, {}).get("style") == "path" %}
        path_params["{{ param.name }}"] = str({{ param.name | safe_identifier }})
        {% elif tool.impl.arg_mapping.get(param.name, {}).get("style") == "body" %}
        request_body = {{ param.name | safe_identifier }} if isinstance({{ param.name | safe_identifier }}, dict) else {"data": {{ param.name | safe_identifier }}}
        {% else %}
        if {{ param.name | safe_identifier }} is not None:
            query_params["{{ param.name }}"] = str({{ param.name | safe_identifier }})
        {% endif %}
        {% endfor %}
        try:
            return await backend.request(
                "{{ tool.impl.http_method }}",
                "{{ tool.impl.http_path }}",
                params=query_params or None,
                body=request_body,
                path_params=path_params or None,
            )
        except BackendError as exc:
            return json.dumps(exc.to_dict(), indent=2)
    {% elif tool.impl.strategy == "cli_subcommand" %}
        # Run CLI subcommand: {{ tool.impl.cli_subcommand }}
        cmd_args: list[str] = []
        {% for param in tool.parameters %}
        {% if tool.impl.arg_mapping.get(param.name, {}).get("style") == "passthrough" %}
        if {{ param.name | safe_identifier }}:
            cmd_args.extend({{ param.name | safe_identifier }}.split())
        {% elif tool.impl.arg_mapping.get(param.name, {}).get("style") == "flag" %}
        if {{ param.name | safe_identifier }} is not None:
        {% if param.type == "boolean" %}
            if {{ param.name | safe_identifier }}:
                cmd_args.append("{{ tool.impl.arg_mapping[param.name]['flag'] }}")
        {% else %}
            cmd_args.extend(["{{ tool.impl.arg_mapping[param.name]['flag'] }}", str({{ param.name | safe_identifier }})])
        {% endif %}
        {% else %}
        if {{ param.name | safe_identifier }} is not None:
            cmd_args.append(str({{ param.name | safe_identifier }}))
        {% endif %}
        {% endfor %}
        return await backend.run_subcommand("{{ tool.impl.cli_subcommand }}", cmd_args)
    {% elif tool.impl.strategy == "cli_function" %}
        # Call function via CLI backend: {{ tool.impl.cli_entry }}::{{ tool.impl.python_function }}
        return await backend.run_function_as_cli(
            "{{ tool.impl.cli_entry }}",
            "{{ tool.impl.python_function }}",
        {% for param in tool.parameters %}
            {% if param.required %}
            {{ param.name | safe_identifier }}={{ param.name | safe_identifier }},
            {% else %}
            **({"{{ param.name }}": {{ param.name | safe_identifier }}} if {{ param.name | safe_identifier }} is not None else {}),
            {% endif %}
        {% endfor %}
        )
    {% elif tool.impl.strategy == "protocol_call" %}
        # Protocol call: {{ tool.name }}
        kwargs: dict[str, object] = {}
        {% for param in tool.parameters %}
        if {{ param.name | safe_identifier }} is not None:
            kwargs["{{ param.name }}"] = {{ param.name | safe_identifier }}
        {% endfor %}
        try:
            return await backend.execute("{{ tool.name }}", **kwargs)
        except BackendError as exc:
            return json.dumps(exc.to_dict(), indent=2)
    {% elif tool.impl.strategy == "python_call" %}
    {% if tool.impl.python_class %}
        # Instance method: {{ tool.impl.python_module }}.{{ tool.impl.python_class }}.{{ tool.impl.python_function }}
        _setup_import_path("{{ design.backend.codebase_path if design.backend else '' }}")
        mod = _load_source_module("{{ design.backend.codebase_path if design.backend else '' }}", "{{ tool.impl.python_module }}")
        cls = getattr(mod, "{{ tool.impl.python_class }}")
        kwargs = {}
        {% for param in tool.parameters %}
            {% if param.required %}
        kwargs["{{ param.name }}"] = {{ param.name | safe_identifier }}
            {% else %}
        if {{ param.name | safe_identifier }} is not None:
            kwargs["{{ param.name }}"] = {{ param.name | safe_identifier }}
            {% endif %}
        {% endfor %}
        method_attr = inspect.getattr_static(cls, "{{ tool.impl.python_function }}")
        if isinstance(method_attr, (staticmethod, classmethod)):
            # Static/class method — call directly on the class
            result = getattr(cls, "{{ tool.impl.python_function }}")(**kwargs)
        else:
            # Instance method — auto-instantiate the class
            init_kwargs = {}
        {% for ip in tool.impl.python_init_params %}
        {% if ip.required and not ip.default and ip.name != "self" %}
            if init_{{ ip.name | safe_identifier }} is not None:
                init_kwargs["{{ ip.name }}"] = init_{{ ip.name | safe_identifier }}
        {% endif %}
        {% endfor %}
            instance = _get_or_create_instance(mod, "{{ tool.impl.python_class }}", **init_kwargs)
            result = getattr(instance, "{{ tool.impl.python_function }}")(**kwargs)
        if inspect.isawaitable(result):
            result = await result
        return str(result) if result is not None else "OK"
    {% else %}
        # Direct Python call: {{ tool.impl.python_module }}.{{ tool.impl.python_function }}
        _setup_import_path("{{ design.backend.codebase_path if design.backend else '' }}")
        _src_mod = _load_source_module("{{ design.backend.codebase_path if design.backend else '' }}", "{{ tool.impl.python_module }}")
        {{ tool.impl.python_function }} = getattr(_src_mod, "{{ tool.impl.python_function }}")
        result = {{ tool.impl.python_function }}(
        {% for param in tool.parameters %}
            {% if param.required %}
            {{ param.name | safe_identifier }}={{ param.name | safe_identifier }},
            {% else %}
            **({"{{ param.name }}": {{ param.name | safe_identifier }}} if {{ param.name | safe_identifier }} is not None else {}),
            {% endif %}
        {% endfor %}
        )
        if inspect.isawaitable(result):
            result = await result
        return str(result) if result is not None else "OK"
    {% endif %}
    {% else %}
        # Stub — implementation not yet generated
        {% if design.backend %}
        return await backend.run_subcommand("{{ tool.name }}")
        {% else %}
        raise NotImplementedError("{{ tool.name }} not yet implemented")
        {% endif %}
    {% endif %}

