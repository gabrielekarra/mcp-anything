class TestToolErrorHandling:
    """Verify backend failures are surfaced predictably."""

    @pytest.mark.parametrize(
        ("tool_name", "tool_input", "strategy"),
        [
{% for tool in tools %}
{% if tool.impl.strategy in ["http_call", "protocol_call"] %}
            (
                "{{ tool.name }}",
                {
{% for param in tool.parameters %}
                    "{{ param.name }}": {{ sample_value(param.type, param.name) }},
{% endfor %}
                },
                "{{ tool.impl.strategy }}",
            ),
{% endif %}
{% endfor %}
        ],
    )
    def test_backend_error_is_serialized(self, server, server_module, monkeypatch, tool_name, tool_input, strategy):
        if strategy == "http_call":
            error = BackendError(
                "backend-failed",
                status_code=502,
                method="GET",
                path="/failure",
                response_body="upstream error",
            )
            monkeypatch.setattr(server_module._backend, "request", AsyncMock(side_effect=error))
        else:
            error = BackendError(
                "backend-failed",
                method=tool_name,
                response_body="upstream error",
            )
            monkeypatch.setattr(server_module._backend, "execute", AsyncMock(side_effect=error))

        result = _run(server.call_tool(tool_name, tool_input))

        payload = json.loads(_extract_text_result(result))
        assert payload["error"] == "backend-failed"
        assert payload["response_body"] == "upstream error"
        if strategy == "http_call":
            assert payload["status_code"] == 502
            assert payload["path"] == "/failure"
        else:
            assert payload["method"] == tool_name
{% endif %}


