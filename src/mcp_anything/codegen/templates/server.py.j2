"""MCP server for {{ design.server_name }}."""

import os

from mcp.server.fastmcp import FastMCP

{% if design.enable_server_auth %}
# ── OAuth 2.1 authorization server (authorization code + PKCE) ───────────────
# Protects the MCP server so clients like Claude must authenticate first.
# Set {{ design.server_auth_env_var }} to the shared token users enter in the
# browser login form when authorizing a new connection.
from mcp.server.auth.settings import AuthSettings, ClientRegistrationOptions
from {{ package_name }}._auth_provider import oauth_provider, login_routes

_issuer_url = os.environ.get("MCP_SERVER_URL", "http://localhost:{{ design.http_port }}")

server = FastMCP(
    "{{ design.server_name }}",
    auth=AuthSettings(
        issuer_url=_issuer_url,
        resource_server_url=_issuer_url,
        client_registration_options=ClientRegistrationOptions(
            enabled=True,
            valid_scopes=["mcp"],
            default_scopes=["mcp"],
        ),
        required_scopes=["mcp"],
    ),
    auth_server_provider=oauth_provider,
)

# Register the login form routes
server._custom_starlette_routes.extend(login_routes)
{% else %}
server = FastMCP("{{ design.server_name }}")
{% endif %}

{% if design.enable_telemetry %}
# OpenTelemetry instrumentation — must be set up before tool registration
try:
    from opentelemetry import trace
    from opentelemetry.sdk.trace import TracerProvider
    from opentelemetry.sdk.trace.export import BatchSpanProcessor
    from opentelemetry.exporter.otlp.proto.grpc.trace_exporter import OTLPSpanExporter

    provider = TracerProvider()
    otlp_endpoint = os.environ.get("OTEL_EXPORTER_OTLP_ENDPOINT")
    if otlp_endpoint:
        provider.add_span_processor(BatchSpanProcessor(OTLPSpanExporter(endpoint=otlp_endpoint)))
    trace.set_tracer_provider(provider)
    _tracer = trace.get_tracer("{{ design.server_name }}")
except ImportError:
    _tracer = None
{% endif %}

{% if design.backend %}
from {{ package_name }}.backend import Backend

_backend = Backend()
{% endif %}

# Import and register tool modules
{% for module_name in design.tool_modules %}
from {{ package_name }}.tools.{{ module_name }} import register_tools as register_{{ module_name }}_tools
register_{{ module_name }}_tools(server{% if design.backend %}, _backend{% endif %}{% if design.enable_telemetry %}, _tracer{% endif %})
{% endfor %}

{% if design.resources %}
# Import and register resources
from {{ package_name }}.resources import register_resources
register_resources(server{% if design.backend %}, _backend{% endif %})
{% endif %}

{% if design.prompts %}
# Import and register prompts
from {{ package_name }}.prompts import register_prompts
register_prompts(server)
{% endif %}


def main():
    """Run the MCP server."""
    transport = os.environ.get("MCP_TRANSPORT", "{{ design.transport }}")

    if transport == "http":
        host = os.environ.get("MCP_HOST", "{{ design.http_host }}")
        port = int(os.environ.get("MCP_PORT", "{{ design.http_port }}"))
        server.settings.host = host
        server.settings.port = port
        server.run(transport="streamable-http")
    else:
        server.run(transport="stdio")


if __name__ == "__main__":
    main()
